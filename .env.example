# 应用环境配置
# --------------------------------------------------------------
# 应用运行环境：development（开发）/production（生产）
FLASK_ENV=development
# 是否开启Flask调试模式
FLASK_DEBUG=True
# 是否开启调试模式
DEBUG=True
# --------------------------------------------------------------

# 数据库配置（请替换为您的安全数据库连接）
# --------------------------------------------------------------
# 主数据库
SQLALCHEMY_DATABASE_URI=""
# 测试环境数据库
SQLALCHEMY_DATABASE_URI_TEST=""
# 开发环境数据库
SQLALCHEMY_DATABASE_URI_DEV=""
# --------------------------------------------------------------

# 对象存储配置（请替换为您的OSS信息）
# --------------------------------------------------------------
OSS_ACCESS_KEY_ID="your_oss_access_key_id_here"
OSS_ACCESS_KEY_SECRET="your_oss_access_key_secret_here"

# 生产环境OSS配置
OSS_ENDPOINT="oss-your-region.aliyuncs.com"
OSS_BUCKET_NAME="your-bucket-name"
OSS_HOST="http://your-oss-host.com"

# 测试环境OSS配置
OSS_ENDPOINT_TEST="oss-your-test-region.aliyuncs.com"
OSS_BUCKET_NAME_TEST="your-test-bucket-name"
OSS_HOST_TEST="http://your-test-oss-host.com"

# 开发环境OSS配置
OSS_ENDPOINT_DEV="oss-your-dev-region.aliyuncs.com"
OSS_BUCKET_NAME_DEV="your-dev-bucket-name"
OSS_HOST_DEV="http://your-dev-oss-host.com"
# --------------------------------------------------------------

# Redis配置（请替换为您的Redis连接信息）
# --------------------------------------------------------------
REDIS_URL=""
REDIS_URL_TEST=""
REDIS_URL_DEV=""
# --------------------------------------------------------------

# 缓存配置
# --------------------------------------------------------------
# 缓存默认超时时间（秒）
CACHE_DEFAULT_TIMEOUT=300
# 缓存类型
CACHE_TYPE="redis"
# --------------------------------------------------------------

# JWT认证配置（请使用安全随机生成的密钥）
# --------------------------------------------------------------
JWT_SECRET_KEY="your_secure_random_jwt_secret_key_here"
# 访问令牌有效期（小时）
JWT_ACCESS_TOKEN_EXPIRES=24
# 刷新令牌有效期（小时）
JWT_REFRESH_TOKEN_EXPIRES=168
# --------------------------------------------------------------

# 日志配置
# --------------------------------------------------------------
# 日志目录
LOG_DIRECTORY="logs/large_requests"
# 最大日志文件大小（字节）
MAX_LOG_SIZE=1048576
# --------------------------------------------------------------

# 定时任务配置
# --------------------------------------------------------------
# Webhook 推送间隔（分钟），默认 1
WEBHOOK_PUSH_INTERVAL_MINUTES=1
# 库存快照执行时间（24小时制），默认凌晨 2:00
SNAPSHOT_HOUR=2
SNAPSHOT_MINUTE=0
# --------------------------------------------------------------

# 安全配置
# --------------------------------------------------------------
# 是否检查白名单
CHECK_WHITELIST=False
# 是否检查黑名单
CHECK_BLACKLIST=True
# --------------------------------------------------------------
